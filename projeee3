bakiye = 5000
islem_gecmisi = []

kullanici_adi = "admin"
sifre = "1234"


def giris():
    global kullanici_adi, sifre

    ad = input("Kullanıcı adı: ")
    s = input("Şifre: ")

    if ad == kullanici_adi and s == sifre:
        print("Giriş başarılı")
        return True
    else:
        print("Hatalı giriş")
        return False


def menu():
    print("\n--- ATM MENÜ ---")
    print("1 - Bakiye Görüntüle")
    print("2 - Para Yatır")
    print("3 - Para Çek")
    print("4 - İşlem Geçmişi")
    print("5 - Sadece Çekilen İşlemler")
    print("6 - Çıkış")


def bakiye_goster():
    print("Bakiyeniz:", bakiye, "TL")


def para_yatir():
    global bakiye

    miktar = int(input("Yatırılacak miktar: "))

    if miktar <= 0:
        print("Geçersiz miktar")
        return

    bakiye += miktar
    islem_gecmisi.append(f"{miktar} TL yatırıldı")
    print("Para yatırıldı")


def para_cek():
    global bakiye

    miktar = int(input("Çekilecek miktar: "))

    if miktar <= 0:
        print("Geçersiz miktar")
        return

    if miktar > bakiye:
        print("Yetersiz bakiye")
        return

    bakiye -= miktar
    islem_gecmisi.append(f"{miktar} TL çekildi")
    print("Paranız veriliyor...")


def gecmis_goster():
    if len(islem_gecmisi) == 0:
        print("Henüz işlem yok")
        return

    for i, islem in enumerate(islem_gecmisi, start=1):
        print(i, "-", islem)


def cekilenleri_goster():
    cekimler = list(filter(lambda x: "çekildi" in x, islem_gecmisi))

    if len(cekimler) == 0:
        print("Çekme işlemi yok")
        return

    for c in cekimler:
        print(c)


while True:

    if not giris():
        continue

    while True:
        menu()
        secim = input("Seçiminiz: ")

        if secim == "1":
            bakiye_goster()

        elif secim == "2":
            para_yatir()

        elif secim == "3":
            para_cek()

        elif secim == "4":
            gecmis_goster()

        elif secim == "5":
            cekilenleri_goster()

        elif secim == "6":
            print("Çıkış yapıldı")
            break

        else:
            print("Geçersiz seçim")







